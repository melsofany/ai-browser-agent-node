# Cloud AI (primary)
DEEPSEEK_API_KEY=

# Local AI via Ollama (fallback when DeepSeek not set)
# Install Ollama: https://ollama.ai
# Then run: ollama pull llama3 (or mistral, qwen2, deepseek-r1, etc.)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
USE_LOCAL_MODELS=true

# Memory backend: 'memory' (default), 'sqlite'
MEMORY_BACKEND=sqlite

# GitHub (optional)
GITHUB_TOKEN=
GITHUB_REPO_URL=
